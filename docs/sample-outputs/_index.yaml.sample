    produced_at: 2026-05-13T09:13:55Z
    source_hash: sha256:c19f...
    schemas_covered: [public]

  conventions_index:
    path: conventions/_index.md
    produced_by: scan-init
    produced_at: 2026-05-13T09:14:01Z

  build_index:
    path: build/_index.yaml

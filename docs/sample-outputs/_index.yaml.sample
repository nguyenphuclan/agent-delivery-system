# Sample _index.yaml — output of scan-init
# Lives at: {project_docs}/_index.yaml
# Every artifact the agent produces is registered here. Skills resolve paths via this file.

schema_version: 1
project: myapp
last_full_scan: 2026-05-13T09:14:22Z

# ─── Phase readiness gates ───────────────────────────────────────────────
# Each phase flips to `ready` only when its inputs are present and fresh.
# do-ticket / domain-problem-solver consult this map before advancing.
phase_readiness:
  scan_complete:        ready
  domain_index_built:   ready
  ticket_context_built: not_started     # set by do-ticket per-ticket
  plan_built:           not_started
  implementation_done:  not_started
  tests_passing:        not_started
  pr_ready:             not_started

# ─── Artifact registry ───────────────────────────────────────────────────
artifacts:

  domain_index:

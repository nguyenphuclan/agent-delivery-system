    produced_at: 2026-05-13T09:14:22Z
    source_hash: sha256:8e2b...
    phase: domain_index_built

  code_index:
    path: code/_index.yaml
    produced_by: scan-init
    produced_at: 2026-05-13T09:11:08Z
